# ─── Production deployment (Vercel frontend) ───
#
# Option A — CMS-only on Vercel (no Postgres):
#   Leave VITE_API_URL empty.
#   Set in Vercel → Settings → Environment Variables:
#     ADMIN_PASSWORD=your-secure-password
#     ADMIN_SECRET=long-random-string
#   Admin login: /admin/login
#   CMS saves to data/site-content.json (export & commit for permanent changes).
#
# Option B — Full backend (forms, PayPal, enrollments, Postgres):
#   Deploy server/ separately (Railway, Render, Fly.io, DigitalOcean, etc.).
#   Set in Vercel (build env):
#     VITE_API_URL=https://your-api-host.example.com
#   Set on the API host (server/.env):
#     DATABASE_URL=postgresql://...
#     ADMIN_PASSWORD=...
#     JWT_SECRET=long-random-string
#     PAYPAL_* / DO_SPACES_* as needed
#
# Local dev: Vite proxies /api/* to Express on :4000 (see vite.config.js).

VITE_API_URL=

# Optional: resolve bare object keys (uploads/foo.jpg) to your Spaces CDN.
# VITE_DO_SPACES_CDN_URL=https://your-space.nyc3.cdn.digitaloceanspaces.com
