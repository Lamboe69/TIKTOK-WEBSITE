# Frontend note: Vite proxies /api/* (except /api/stats) to the Dynasty API on :4000
# Backend config lives in server/.env

VITE_API_URL=

# Optional: resolve bare object keys (uploads/foo.jpg) to your Spaces CDN.
# Full https:// URLs and /photos/… paths work without this.
# VITE_DO_SPACES_CDN_URL=https://your-space.nyc3.cdn.digitaloceanspaces.com
