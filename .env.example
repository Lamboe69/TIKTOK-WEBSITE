# ─── Self-hosted nginx + Express ───
#
# 1. Build frontend (same domain — leave apiUrl empty):
#      npm run build
#    Copy dist/ → /var/www/km-dynasty/dist
#
# 2. Run API on the server (port 4000):
#      cd server && npm run setup && npm run start
#
# 3. nginx: see deploy/nginx.conf.example
#    Must include location /api/ { proxy_pass http://127.0.0.1:4000; }
#    BEFORE location / { try_files ... }
#
# 4. Optional runtime override without rebuild:
#    Edit dist/km-config.js → apiUrl: ''  (same domain)
#
# ─── Production: API subdomain + Caddy (recommended) ───
#   Frontend: https://test.kmdynasty.org
#   API:      https://api.kmdynasty.org
#   Build:    VITE_API_URL=https://api.kmdynasty.org npm run build
#   Guide:    deploy/CADDY-SETUP.md
#
# Local dev: leave VITE_API_URL empty (Vite proxies /api to :4000)
# Production: see .env.production (https://api.kmdynasty.org) or public/km-config.js

VITE_API_URL=

# Optional CDN for Spaces media keys
# VITE_DO_SPACES_CDN_URL=https://your-space.nyc3.cdn.digitaloceanspaces.com
