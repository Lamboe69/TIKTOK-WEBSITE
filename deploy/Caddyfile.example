# KM Dynasty — Caddy (frontend + API subdomain)
#
# DNS (both → your server IP, e.g. 72.62.133.240):
#   test.kmdynasty.org   A  →  YOUR_SERVER_IP
#   api.kmdynasty.org    A  →  YOUR_SERVER_IP
#
# Frontend build (repo root):
#   VITE_API_URL=https://api.kmdynasty.org npm run build
#   sudo rsync -av --delete dist/ /var/www/km-dynasty/dist/
#
# Backend (server/.env):
#   SERVE_STATIC=0
#   HOST=127.0.0.1
#   PORT=4000
#
# Install: see deploy/CADDY-SETUP.md

# ─── API (Express on :4000) ───
api.kmdynasty.org {
	reverse_proxy 127.0.0.1:4000
}

# ─── Frontend (React SPA) ───
test.kmdynasty.org {
	root * /var/www/km-dynasty/dist
	encode gzip
	file_server
	try_files {path} /index.html
}

# Optional: redirect apex to test (uncomment if you own kmdynasty.org)
# kmdynasty.org, www.kmdynasty.org {
# 	redir https://test.kmdynasty.org{uri} permanent
# }
