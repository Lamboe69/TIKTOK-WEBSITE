# Add this as a NEW site — do not change test.kmdynasty.org config
#
# sudo cp deploy/nginx-api-only.conf.example /etc/nginx/sites-available/api.kmdynasty.org
# sudo ln -s /etc/nginx/sites-available/api.kmdynasty.org /etc/nginx/sites-enabled/
# sudo nginx -t && sudo systemctl reload nginx
#
# Get SSL cert:
# sudo certbot --nginx -d api.kmdynasty.org

server {
    listen 80;
    listen [::]:80;
    server_name api.kmdynasty.org;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name api.kmdynasty.org;

    # certbot fills these after: sudo certbot --nginx -d api.kmdynasty.org
    ssl_certificate     /etc/letsencrypt/live/api.kmdynasty.org/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/api.kmdynasty.org/privkey.pem;

    client_max_body_size 25m;

    location / {
        proxy_pass http://127.0.0.1:4000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
