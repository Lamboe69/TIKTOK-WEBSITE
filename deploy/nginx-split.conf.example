# Frontend: nginx serves /var/www/km-dynasty/dist (already working)
# Backend:  Node API only on 127.0.0.1:4000 — nginx proxies /api/ and /uploads/
#
# server/.env:
#   SERVE_STATIC=0
#   HOST=127.0.0.1
#   PORT=4000
#
# Start API: cd server && pm2 start ecosystem.config.cjs

server {
    listen 80;
    listen [::]:80;
    server_name test.kmdynasty.org;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name test.kmdynasty.org;

    ssl_certificate     /etc/letsencrypt/live/test.kmdynasty.org/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/test.kmdynasty.org/privkey.pem;

    root /var/www/km-dynasty/dist;
    index index.html;

    client_max_body_size 25m;

    # Backend API — must proxy POST (login, forms, PayPal)
    location ^~ /api/ {
        proxy_pass http://127.0.0.1:4000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location ^~ /uploads/ {
        proxy_pass http://127.0.0.1:4000;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Frontend SPA (already working)
    location / {
        try_files $uri $uri/ /index.html;
    }
}
