# Dynasty API
PORT=4000
HOST=0.0.0.0
DATABASE_URL=postgresql://walternyeko@localhost:5432/dynasty
ADMIN_EMAIL=admin@kmdynasty.com
ADMIN_PASSWORD=km-dynasty-admin
JWT_SECRET=change-me-to-a-long-random-string
JWT_TTL=7d

# Self-hosted nginx (recommended): serve React build from Express — one upstream port
# SERVE_STATIC=1
# STATIC_DIR=/var/www/km-dynasty/dist

# PayPal Checkout (masterclass enrollments)
# Create an app at https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# sandbox | live
PAYPAL_MODE=sandbox
PAYPAL_CURRENCY=USD

# DigitalOcean Spaces (photo uploads). When unset, files save to public/uploads.
# Spaces → API → Spaces Keys; endpoint like nyc3.digitaloceanspaces.com (no https://)
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_BUCKET=
DO_SPACES_ENDPOINT=nyc3.digitaloceanspaces.com
DO_SPACES_REGION=nyc3
# Optional CDN origin (recommended for production)
DO_SPACES_CDN_URL=
# Object key prefix inside the bucket
DO_SPACES_PREFIX=uploads
