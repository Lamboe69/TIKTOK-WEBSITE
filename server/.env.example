# Dynasty API — copy to server/.env (never commit .env)
#
# ─── PICK ONE DEPLOYMENT MODE ───
#
# MODE A — Split (frontend already works on nginx static) ← use this if pages load but API 405
#   SERVE_STATIC=0
#   HOST=127.0.0.1
#   nginx: deploy/nginx-split.conf.example
#
# MODE B — Single upstream (nginx proxies everything to Node)
#   SERVE_STATIC=1
#   STATIC_DIR=/var/www/km-dynasty/dist
#   HOST=0.0.0.0
#   nginx: deploy/nginx-simple.conf.example

# ─── Server ───
PORT=4000
HOST=127.0.0.1

# ─── Static files (MODE B only — set SERVE_STATIC=0 for MODE A) ───
SERVE_STATIC=0
# STATIC_DIR=/var/www/km-dynasty/dist

# ─── Database (Postgres) ───
DATABASE_URL=postgresql://your_user:your_db_password@localhost:5432/dynasty

# ─── Admin login (/admin/login) ───
ADMIN_EMAIL=admin@kmdynasty.com
ADMIN_PASSWORD=change-me-strong-password
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_TTL=7d

# ─── PayPal (masterclass checkout) ───
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
PAYPAL_CURRENCY=USD

# ─── DigitalOcean Spaces (admin image uploads) ───
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_BUCKET=
DO_SPACES_ENDPOINT=nyc3.digitaloceanspaces.com
DO_SPACES_REGION=nyc3
DO_SPACES_CDN_URL=
DO_SPACES_PREFIX=uploads
