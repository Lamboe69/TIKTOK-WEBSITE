# Dynasty API — copy to server/.env (never commit .env)
#
# Local dev:  cd server && cp .env.example .env && npm run setup && npm run dev
# Production:  see deploy/nginx-simple.conf.example

# ─── Server ───
PORT=4000
HOST=0.0.0.0

# ─── Database (Postgres) ───
# Local example:
#   DATABASE_URL=postgresql://your_user@localhost:5432/dynasty
# Production example:
#   DATABASE_URL=postgresql://dynasty_user:your_db_password@localhost:5432/dynasty
DATABASE_URL=postgresql://your_user:your_db_password@localhost:5432/dynasty

# ─── Admin login (/admin/login) ───
ADMIN_EMAIL=admin@kmdynasty.com
ADMIN_PASSWORD=change-me-strong-password
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_TTL=7d

# ─── Self-hosted: Express serves React build (nginx-simple — proxy all to :4000) ───
SERVE_STATIC=1
# After: npm run build (from repo root) && rsync dist/ to web root
STATIC_DIR=/var/www/km-dynasty/dist
# Or point at the project build directly (no rsync):
# STATIC_DIR=/home/your_user/TIKTOK-WEBSITE/dist
# Local dev: comment out SERVE_STATIC or set SERVE_STATIC=0

# ─── PayPal (masterclass checkout) ───
# https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
PAYPAL_CURRENCY=USD

# ─── DigitalOcean Spaces (admin image uploads) ───
# Leave empty to save uploads under public/uploads on the server
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_BUCKET=
DO_SPACES_ENDPOINT=nyc3.digitaloceanspaces.com
DO_SPACES_REGION=nyc3
DO_SPACES_CDN_URL=
DO_SPACES_PREFIX=uploads
